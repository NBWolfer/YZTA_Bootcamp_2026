# HealRoute AI — backend ortam değişkenleri
# Varsayılan olarak MOCK modda çalışır (API key gerekmez).

# Gerçek Gemini entegrasyonunu açmak için true yapın ve key girin:
USE_GEMINI=false
# GEMINI_API_KEY=buraya_key

# Prod'da deploy edilen frontend origin'i (virgülle birden fazla eklenebilir):
# ALLOWED_ORIGINS=https://healroute.vercel.app
